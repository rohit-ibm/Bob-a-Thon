# Monday.com MCP Server Configuration
# Copy this file to .env and fill in your actual API key

# Monday.com API Key
# Get your API key from: https://monday.com -> Admin -> API
# Required permissions: boards:read, boards:write, items:read, items:write
MONDAY_API_KEY=your_monday_api_key_here

# Optional: Monday.com Workspace ID
# If you want to restrict operations to a specific workspace
# MONDAY_WORKSPACE_ID=your_workspace_id_here

# Optional: Default Board ID
# Set a default board ID for quick operations
# MONDAY_DEFAULT_BOARD_ID=your_default_board_id_here